{{- /* RSS feed: no <content:encoded>, sorted desc, safe descriptions, taxonomy categories */ -}}
{{- $pctx := . -}}
{{- if .IsHome -}}{{ $pctx = .Site }}{{- end -}}

{{- /* Select pages: on Home/Section use RegularPages; elsewhere use .Pages */ -}}
{{- $pages := cond (or $.IsHome $.IsSection) $pctx.RegularPages $pctx.Pages -}}
{{- /* Sort newest first */ -}}
{{- $pages = $pages.ByDate.Reverse -}}

{{- /* Limit (same behavior as your template) */ -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
  {{- $pages = first $limit $pages -}}
{{- end -}}

{{- /* Latest item for lastBuildDate fallback */ -}}
{{- $latest := cond (gt (len $pages) 0) (index $pages 0) nil -}}

{{- /* Author params (support both [params.Author] and [params.author]) */ -}}
{{- $author := .Site.Params.Author | default .Site.Params.author -}}

{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0"
     xmlns:atom="http://www.w3.org/2005/Atom"
     xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ if eq  .Title  .Site.Title }}{{ .Site.Title }}{{ else }}{{ with .Title }}{{ . }} on {{ end }}{{ .Site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>

    {{- /* Channel description: keep your original phrasing */ -}}
    <description>
      {{- printf "Recent content %s on %s"
          (cond (ne .Title .Site.Title) (printf "in %s " .Title) "") .Site.Title
        | html -}}
    </description>

    <generator>Hugo -- gohugo.io</generator>
    <language>{{ site.LanguageCode }}</language>

    {{- with $author.email -}}
      <managingEditor>{{ . }}{{ with $author.name }} ({{ . }}){{ end }}</managingEditor>
      <webMaster>{{ . }}{{ with $author.name }} ({{ . }}){{ end }}</webMaster>
    {{- end }}

    {{- if .Site.Params.footer.showCopyright | default true -}}
      <copyright>
        {{- with replace .Site.Params.copyright "{ year }" now.Year -}}
          {{ . }}
        {{- else -}}
          © {{ now.Format "2006" }} {{ with $author.name }}{{ . }}{{ end }}
        {{- end -}}
      </copyright>
    {{- end }}

    {{- /* lastBuildDate: prefer page date if present, else newest item */ -}}
    {{- if not .Date.IsZero -}}
      <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- else if $latest -}}
      <lastBuildDate>{{ $latest.Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- end }}

    {{- with .OutputFormats.Get "RSS" -}}
      {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{- end -}}

    {{- if and (.Site.Params.rssnext.feedId) (.Site.Params.rssnext.userId) }}
      <follow_challenge>
        <feedId>{{ .Site.Params.rssnext.feedId }}</feedId>
        <userId>{{ .Site.Params.rssnext.userId }}</userId>
      </follow_challenge>
    {{- end }}

    {{- range $pages }}
      {{- /* Description: plain text only (summary/description/plain) to avoid XML issues */ -}}
      {{- $idesc := (.Description | default .Summary | default .Plain) | plainify -}}

      <item>
        <title>{{ .Title }}</title>
        <link>{{ .Permalink }}</link>
        <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
        {{ with $author.email }}<author>{{ . }}{{ with $author.name }} ({{ . }}){{ end }}</author>{{ end }}
        <guid isPermaLink="true">{{ .Permalink }}</guid>

        <description>{{ $idesc | html }}</description>

        {{- /* === Taxonomy as RSS categories === */ -}}
        {{- with .Params.tags -}}
          {{- range . -}}<category domain="tags">{{ . }}</category>{{- end -}}
        {{- end }}
        {{- with .Params.categories -}}
          {{- range . -}}<category domain="categories">{{ . }}</category>{{- end -}}
        {{- end }}
        {{- with .Params.series -}}
          {{- $series := . -}}
          {{- if (reflect.IsSlice $series) -}}
            {{- range $series -}}<category domain="series">{{ . }}</category>{{- end -}}
          {{- else -}}
            <category domain="series">{{ $series }}</category>
          {{- end -}}
        {{- end }}
        {{- with .Params.authors -}}
          {{- range . -}}<category domain="authors">{{ . }}</category>{{- end -}}
        {{- end }}

        {{- /* Featured image from page bundle (optional) */ -}}
        {{- $images := .Resources.ByType "image" -}}
        {{- $featured := $images.GetMatch "*feature*" -}}
        {{- if not $featured }}{{ $featured = $images.GetMatch "{*cover*,*thumbnail*}" }}{{ end -}}
        {{- with $featured -}}
          <media:content url="{{ .Permalink }}" medium="image" />
        {{- end -}}
      </item>
    {{- end }}
  </channel>
</rss>
